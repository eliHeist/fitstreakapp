<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FitStreak.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FitStreak.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- =========================================================
         Tab Bar — 4 main tabs
         ========================================================= -->
    <TabBar>

        <!-- Tab 1: Home / Today -->
        <ShellContent
            Title="Today"
            Icon="icon_home.png"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="home" />

        <!-- Tab 2: Workout Library -->
        <ShellContent
            Title="Workouts"
            Icon="icon_workouts.png"
            ContentTemplate="{DataTemplate views:WorkoutsPage}"
            Route="workouts" />

        <!-- Tab 3: Schedule / Calendar -->
        <ShellContent
            Title="Schedule"
            Icon="icon_schedule.png"
            ContentTemplate="{DataTemplate views:SchedulePage}"
            Route="schedule" />

        <!-- Tab 4: Streak Map -->
        <ShellContent
            Title="Streaks"
            Icon="icon_streak.png"
            ContentTemplate="{DataTemplate views:StreakPage}"
            Route="streaks" />

    </TabBar>

</Shell>
