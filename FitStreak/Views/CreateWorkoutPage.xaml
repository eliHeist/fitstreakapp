<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FitStreak.Views.CreateWorkoutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:FitStreak.Core.Models.Workout;assembly=FitStreak.Core"
    xmlns:vm="clr-namespace:FitStreak.ViewModels"
    x:DataType="vm:CreateWorkoutViewModel"
    BackgroundColor="#0F0F0F">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="Save"
            Command="{Binding SaveWorkoutCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- Header -->
            <VerticalStackLayout Spacing="4" Margin="0,16,0,0">
                <Label
                    Text="{Binding Title}"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#FFFFFF" />
                <Label
                    Text="Fill in the details and add exercises"
                    FontSize="13"
                    TextColor="#555555" />
            </VerticalStackLayout>

            <!-- =========================================================
                 Workout Details
                 ========================================================= -->
            <Border BackgroundColor="#1A1A1A" Stroke="#2A2A2A" StrokeThickness="1" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <Label Text="WORKOUT DETAILS" FontSize="10" CharacterSpacing="2" TextColor="#666666" FontAttributes="Bold" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Name" FontSize="13" TextColor="#888888" />
                        <Border BackgroundColor="#111111" Stroke="#333333" StrokeThickness="1" Padding="12,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding WorkoutName}"
                                Placeholder="e.g. Push Day"
                                PlaceholderColor="#444444"
                                TextColor="#FFFFFF"
                                FontSize="15"
                                BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Description (optional)" FontSize="13" TextColor="#888888" />
                        <Border BackgroundColor="#111111" Stroke="#333333" StrokeThickness="1" Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Editor
                                Text="{Binding WorkoutDescription}"
                                Placeholder="Describe this workout..."
                                PlaceholderColor="#444444"
                                TextColor="#FFFFFF"
                                FontSize="14"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="60" />
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- =========================================================
                 Add Exercise Form
                 ========================================================= -->
            <Border BackgroundColor="#1A1A1A" Stroke="#2A2A2A" StrokeThickness="1" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <Label Text="ADD EXERCISE" FontSize="10" CharacterSpacing="2" TextColor="#666666" FontAttributes="Bold" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Exercise Name" FontSize="13" TextColor="#888888" />
                        <Border BackgroundColor="#111111" Stroke="#333333" StrokeThickness="1" Padding="12,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding ExerciseName}"
                                Placeholder="e.g. Diamond Push-ups"
                                PlaceholderColor="#444444"
                                TextColor="#FFFFFF"
                                FontSize="15"
                                BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Duration (seconds)" FontSize="13" TextColor="#888888" />
                            <Border BackgroundColor="#111111" Stroke="#333333" StrokeThickness="1" Padding="12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Entry
                                    Text="{Binding ExerciseDuration}"
                                    Keyboard="Numeric"
                                    TextColor="#FFFFFF"
                                    FontSize="15"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Rest after (seconds)" FontSize="13" TextColor="#888888" />
                            <Border BackgroundColor="#111111" Stroke="#333333" StrokeThickness="1" Padding="12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Entry
                                    Text="{Binding ExerciseRest}"
                                    Keyboard="Numeric"
                                    TextColor="#FFFFFF"
                                    FontSize="15"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Notes (optional)" FontSize="13" TextColor="#888888" />
                        <Border BackgroundColor="#111111" Stroke="#333333" StrokeThickness="1" Padding="12,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding ExerciseNotes}"
                                Placeholder="e.g. Keep elbows close"
                                PlaceholderColor="#444444"
                                TextColor="#FFFFFF"
                                FontSize="14"
                                BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <Button
                        Text="+ Add Exercise"
                        BackgroundColor="#1E3A1E"
                        TextColor="#39D353"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="12"
                        Padding="0,14"
                        Command="{Binding AddExerciseCommand}" />

                </VerticalStackLayout>
            </Border>

            <!-- =========================================================
                 Exercise List
                 ========================================================= -->
            <VerticalStackLayout Spacing="12" IsVisible="{Binding Exercises.Count}">

                <Label Text="EXERCISES" FontSize="10" CharacterSpacing="2" TextColor="#666666" FontAttributes="Bold" />

                <CollectionView ItemsSource="{Binding Exercises}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Exercise">
                            <Border
                                BackgroundColor="#141414"
                                Stroke="#2A2A2A"
                                StrokeThickness="1"
                                Padding="14,12"
                                Margin="0,0,0,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <!-- Order index -->
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="#222222"
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        VerticalOptions="Center"
                                        Margin="0,0,12,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label
                                            Text="{Binding OrderIndex, StringFormat='{0}'}"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="#39D353"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <!-- Exercise details -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold" TextColor="#FFFFFF" />
                                        <HorizontalStackLayout Spacing="12" Margin="0,2,0,0">
                                            <Label Text="{Binding DurationSeconds, StringFormat='⏱ {0}s'}" FontSize="12" TextColor="#39D353" />
                                            <Label Text="{Binding RestAfterSeconds, StringFormat='Rest {0}s'}" FontSize="12" TextColor="#555555" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Delete -->
                                    <Button
                                        Grid.Column="2"
                                        Text="✕"
                                        FontSize="13"
                                        BackgroundColor="#2D1515"
                                        TextColor="#F44336"
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        CornerRadius="8"
                                        Padding="0"
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateWorkoutViewModel}}, Path=RemoveExerciseCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <!-- Save button -->
            <Button
                Text="Save Workout"
                BackgroundColor="#39D353"
                TextColor="#0F0F0F"
                FontAttributes="Bold"
                FontSize="16"
                CornerRadius="14"
                Padding="0,16"
                Margin="0,8,0,0"
                Command="{Binding SaveWorkoutCommand}" />

            <!-- Error -->
            <Label
                IsVisible="{Binding HasError}"
                Text="{Binding ErrorMessage}"
                TextColor="#F44336"
                FontSize="13"
                HorizontalOptions="Center" />

            <BoxView HeightRequest="20" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
